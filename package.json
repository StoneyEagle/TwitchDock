{
  "name": "twitchdock",
  "version": "1.0.1",
  "description": "Lightweight Twitch chat dock with FrankerFaceZ support",
  "author": "Stoney_Eagle",
  "main": "src/main.js",
  "scripts": {
  "start": "electron .",
  "dev": "electron . --dev",
  "build": "electron-builder --dir",
  "dist": "electron-builder"
  },
  "build": {
  "appId": "com.stoneyeagle.twitchdock",
  "productName": "TwitchDock",
  "files": [
    "src/**/*",
    "assets/**/*"
  ],
  "asarUnpack": [
    "assets/extensions/**/*"
  ],
  "win": {
    "target": "nsis",
    "icon": "assets/icon.ico"
  },
  "nsis": {
    "oneClick": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "TwitchDock"
  },
  "mac": {
    "target": "dmg",
    "icon": "assets/icon.png"
  },
  "linux": {
    "target": "AppImage",
    "icon": "assets/icon.png"
  }
  },
  "devDependencies": {
  "electron": "^39.8.5",
  "electron-builder": "^26.8.1"
  },
  "overrides": {
  "fast-uri": "^3.1.2",
  "@xmldom/xmldom": "^0.8.13",
  "ip-address": "^10.1.1",
  "lodash": "^4.18.1",
  "brace-expansion@>=5.0.0 <5.0.6": "^5.0.6"
  }
}
